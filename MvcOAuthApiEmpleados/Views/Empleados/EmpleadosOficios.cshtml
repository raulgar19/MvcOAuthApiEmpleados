@model IEnumerable<MvcOAuthApiEmpleados.Models.Empleado>

@{
    ViewData["Title"] = "EmpleadosOficios";
}

@{
    List<string> oficios = ViewData["OFICIOS"] as List<string>;
}

<h1>Empleados Oficios Api</h1>

<form method="post">
    <div class="form-group">
        <label for="incremento">Incremento:</label>
        <input type="number" class="form-control"name="incremento" />
    </div>
    <div class="form-group">
        <label for="oficio">Oficio:</label>
        <select multiple size="5" class="form-control" name="oficio">
            @foreach (string oficio in oficios)
            {
                <option value="@oficio">@oficio</option>
            }
        </select>
    </div>
    <button class="btn btn-info" value="show" name="accion">Mostrar</button>
    <button class="btn btn-warning" value="update" name="accion">Incrementar salarios</button>
</form>

@if (Model != null)
{
    <table class="table">
        <thead>
            <tr>
                <th>IdEmpleado</th>
                <th>Apellido</th>
                <th>Oficio</th>
                <th>Salario</th>
                <th>IdDepartamento</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.IdEmpleado)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Apellido)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Oficio)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Salario)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.IdDepartamento)
                </td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { /* id=item.PrimaryKey */ }) |
                    @Html.ActionLink("Details", "Details", new { /* id=item.PrimaryKey */ }) |
                    @Html.ActionLink("Delete", "Delete", new { /* id=item.PrimaryKey */ })
                </td>
            </tr>
    }
        </tbody>
    </table>
}